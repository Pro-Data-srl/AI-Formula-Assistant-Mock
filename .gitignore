# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db
ehthumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — nur .env.example darf committed/gepusht werden
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------------------------
# IDEs & editors
# ------------------------------------------------------------------------------

# JetBrains (WebStorm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code (uncomment and add !.vscode/settings.json if you want to commit shared settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Cursor (workspace-local rules, skills, cache, logs)
.cursor/

# ------------------------------------------------------------------------------
# Framework / tooling
# ------------------------------------------------------------------------------

# Drizzle (local dev / cache; migrations in drizzle/ are usually committed)
.drizzle/

# Turbo
.turbo

# ESLint cache
.eslintcache

# Optional npm cache
.npm

# Optional stylelint cache
.stylelintcache
