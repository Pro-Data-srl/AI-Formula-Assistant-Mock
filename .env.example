# Provider API keys (set the ones you use)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# LLM use cases: format provider:model[:reasoning|temperature] (optional; defaults shown)
# Third part: either reasoning (none|low|medium|high) or temperature (0–2), not both
# AGENTIC_RAG_LLM defaults to :none on Anthropic (plan/check use structured output; extended thinking conflicts).
# Pricing (per 1M tokens, standard): gpt-4o-mini ≈ $0.15 in / $0.60 out; gpt-5-nano ≈ $0.05 in / $0.40 out (cheaper). gpt-5-mini ≈ $0.25 in / $2.00 out. See https://openai.com/api/pricing
# SIMPLE_CHAT_LLM=openai:gpt-4o-mini
# AGENTIC_CHAT_LLM=openai:gpt-4o-mini
# AGENTIC_RAG_LLM=openai:gpt-4o-mini
# FORMULA_AGENT_LLM=openai:gpt-4o-mini
# COORDINATOR_LLM=anthropic:claude-haiku-4-5:none   (structured planning coordinator; :none on Anthropic)
# TOOL_COORDINATOR_LLM=anthropic:claude-haiku-4-5:low   (tool-calling layer + digest)
# Extended: FORMULA_AGENT_LLM=openai:gpt-4o-mini:medium  or  openai:gpt-4o-mini:0.5

# Embeddings (e.g. for RAG): provider:model
# EMBEDDINGS=openai:text-embedding-3-small

# Conversation title generation (cheapest model). Default: gpt-5-nano ($0.05 in / $0.40 out per 1M tokens)
# TITLE_LLM=openai:gpt-5-nano

# Formula assistant mode: direct | graph | free (legacy: rag → graph, clarification → free)
FORMULA_SOURCE=direct

# Database (optional; defaults to local Docker Postgres)
DATABASE_URL=postgresql://formel:formel@localhost:5433/formel_assistent

# LangSmith (optional; for tracing and metrics when using LangChain/LangGraph)
# LANGSMITH_TRACING=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=formel-assistent

# Debug: Clarification agent status (tool callbacks). Logs to server + browser console.
# DEBUG_CLARIFICATION_STATUS=1
# NEXT_PUBLIC_DEBUG_STATUS=1
